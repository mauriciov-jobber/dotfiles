[user]
  name = Mauricio Vargas
  email = mauricio.v@getjobber.com
  signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDr7MsXja2HU/8zOyYDtrg23mjd6YN8lLsZYqrZjweaL

[fetch]
  prune = true

[commit]
  gpgsign = true

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = {{ .chezmoi.homeDir }}/.ssh/allowed_signers
  defaultKeyCommand = ssh-add -L

[filter "lfs"]
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
  required = true

[core]
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true
  syntax-theme = Dracula
  true-color = always

[merge]
  conflictStyle = zdiff3

[merge "ours"]
  driver = true

[merge "theirs"]
  driver = cp %B %A
